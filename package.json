{
  "name": "github-compliance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:meta && vite --host 0.0.0.0",
    "build": "npm run build:meta && vite build",
    "build:meta": "node scripts/write-build-meta.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "npm run test:unit && npm run test:integration && npm run test:a11y",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "playwright test tests/integration",
    "test:a11y": "playwright test tests/accessibility"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "axe-core": "4.11.4",
    "vite": "8.0.14"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "papaparse": "^5.5.3"
  }
}
